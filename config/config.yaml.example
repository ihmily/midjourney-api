server:
  port: 8080
  mode: debug # debug, release

database:
  host: localhost
  port: 5432
  user: mj_admin
  password: 123456
  dbname: midjourney
  sslmode: disable
  max_idle_conns: 10
  max_open_conns: 100
  log_level: silent # silent, error, warn, info

redis:
  host: localhost
  port: 6379
  password: ""
  db: 0
  pool_size: 10

discord:
  # Global Midjourney Bot command configuration.
  # Account credentials are managed via /api/v1/accounts and stored in the database.
  application_id: "936929561302675456"
  imagine_command_id: "938956540159881230"
  imagine_command_version: "1237876415471554623"
  describe_command_id: "1092492867185950852"
  describe_command_version: "1493662068505706617"
  api_base_url: "https://discord.com/api/v9"
  
task:
  timeout: 300
  max_retries: 3
  queue_name: "mj:task:queue"
  worker_count: 3

oss:
  enable: false
  provider: aliyun           # OSS provider: s3 / aliyun

  s3:
    endpoint_url: "https://s3.ap-southeast-1.amazonaws.com"
    access_key_id: "Your Access Key ID"
    secret_access_key: "Your Secret Access Key"
    region: "ap-southeast-1"
    bucket_name: "midjourney-api"
    prefix: "midjourney"

  aliyun:
    access_key_id: "Your Access Key ID"
    access_key_secret: "Your Access Key Secret"
    endpoint: "https://oss-cn-hangzhou.aliyuncs.com"
    bucket_name: "midjourney-api"
    prefix: "midjourney"
    to_sign: false
    sign_expires: 3600
    is_cname: false
    cname_domain: "https://xxxx.xxxx.com"
